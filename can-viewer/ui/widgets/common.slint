import { LineEdit } from "std-widgets.slint";
import { SigmaTheme } from "../theme.slint";

export struct FrameRow {
    index: int,
    timestamp: string,
    can-id: string,
    channel: string,
    dlc: string,
    data-hex: string,
    message-name: string,
}

export struct SignalRow {
    signal-name: string,
    value: string,
    unit: string,
    raw-value: string,
    description: string,
}

export struct LiveMessageRow {
    can-id: string,
    message-name: string,
    data-hex: string,
    count: string,
    rate: string,
}

export struct LiveSignalRow {
    message-name: string,
    signal-name: string,
    value: string,
    unit: string,
    min-value: string,
    max-value: string,
}

export struct LiveFrameRow {
    timestamp: string,
    can-id: string,
    dlc: string,
    data-hex: string,
    flags: string,
}

export struct LiveErrorRow {
    timestamp: string,
    channel: string,
    error-type: string,
    details: string,
    count: string,
}

export struct DbcMessageRow {
    id: string,
    name: string,
    dlc: string,
    sender: string,
    signal-count: string,
}

export struct DbcSignalRow {
    name: string,
    start-bit: string,
    length: string,
    byte-order: string,
    factor: string,
    unit: string,
}

/// One cell in the Intel bit map. state: 0 empty, 1 other, 2 selected, 3 overflow
export struct DbcBitCell {
    state: int,
    signal-index: int,
}

/// One byte row: cells[0]=bit7 … cells[7]=bit0
export struct DbcBitRow {
    byte-label: string,
    cells: [DbcBitCell],
}

/// One horizontal band of up to 4 byte strips (4-column occupancy grid).
export struct DbcBitBand {
    bytes: [DbcBitRow],
}

export struct DbcNodeRow {
    name: string,
    comment: string,
}

export struct DbcAttributeRow {
    name: string,
    object-type: string,
    value-summary: string,
}

export struct DbcValueDescRow {
    message-id: string,
    signal-name: string,
    entries: string,
}

export struct DepRow {
    name: string,
    version: string,
    license: string,
}

export struct DbcCatalogRow {
    filename: string,
    name: string,
    size-text: string,
}

export component ToolbarButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    in property <bool> enabled: true;
    callback clicked;
    height: 32px;
    opacity: root.enabled ? 1.0 : 0.45;
    background: root.selected
        ? SigmaTheme.accent.transparentize(0.75)
        : (touch.pressed && root.enabled ? SigmaTheme.surface-raised : SigmaTheme.surface);
    border-radius: 4px;
    border-width: 1px;
    border-color: root.selected ? SigmaTheme.accent : SigmaTheme.border;
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        alignment: center;
        Text {
            text: root.label;
            color: root.selected ? SigmaTheme.accent : SigmaTheme.text;
            vertical-alignment: center;
        }
    }
}

/// Header load button. Same wash style as selected tabs, in green/red.
/// Single line: "MDF4: file.mf4" / "DBC: —"
export component FileLoadButton inherits Rectangle {
    in property <string> label;
    in property <string> filename: "";
    in property <bool> loaded: false;
    callback clicked <=> touch.clicked;

    private property <string> display-text:
        root.label + ": " + (root.filename == "" ? "—" : root.filename);

    width: max(180px, label-text.preferred-width + 24px);
    height: 28px;
    background: root.loaded
        ? (touch.pressed
            ? SigmaTheme.accent-green.transparentize(0.55)
            : SigmaTheme.accent-green.transparentize(0.7))
        : (touch.pressed
            ? SigmaTheme.accent-red.transparentize(0.55)
            : SigmaTheme.accent-red.transparentize(0.7));
    border-radius: 4px;
    border-width: 1px;
    border-color: root.loaded ? SigmaTheme.accent-green : SigmaTheme.accent-red;
    clip: true;
    touch := TouchArea {
        width: 100%;
        height: 100%;
    }
    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 10px;
        padding-right: 10px;
        alignment: center;
        label-text := Text {
            text: root.display-text;
            color: root.loaded ? SigmaTheme.accent-green : SigmaTheme.accent-red;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-weight: 600;
            font-size: SigmaTheme.font-size-small;
            overflow: elide;
        }
    }
}

/// Compact labeled field: LineEdit when editable, plain text when read-only.
export component CompactField inherits VerticalLayout {
    in property <string> label;
    in-out property <string> text;
    in property <bool> read-only: false;
    callback edited;
    spacing: 2px;
    alignment: start;
    vertical-stretch: 0;

    Text {
        text: root.label;
        color: SigmaTheme.text-dim;
        font-size: SigmaTheme.font-size-small;
        height: 14px;
    }
    if root.read-only: Text {
        text: root.text;
        color: SigmaTheme.text;
        font-size: SigmaTheme.font-size-small;
        height: 24px;
        vertical-alignment: center;
        overflow: elide;
    }
    if !root.read-only: LineEdit {
        text <=> root.text;
        height: 24px;
        font-size: SigmaTheme.font-size-small;
        edited => { root.edited(); }
    }
}

export component StatusChip inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <brush> value-color: SigmaTheme.text-dim;
    height: 24px;
    background: SigmaTheme.surface;
    border-radius: 4px;
    border-width: 1px;
    border-color: SigmaTheme.border;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        Text { text: root.label; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
        Text { text: root.value; color: root.value-color; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
    }
}
