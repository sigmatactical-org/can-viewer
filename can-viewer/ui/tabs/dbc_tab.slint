import { ListView, ScrollView } from "std-widgets.slint";
import { SigmaTheme } from "../theme.slint";
import { DbcMessageRow, DbcSignalRow, DbcNodeRow, DbcAttributeRow, DbcValueDescRow, DbcBitRow, DbcBitBand, ToolbarButton, StatusChip, CompactField, Cell, HeaderCell, TableHeader, TableRow, EmptyState } from "../widgets/common.slint";
import { SignalBitMap } from "../widgets/bit_map.slint";

export component DbcTab inherits Rectangle {
    callback new-dbc();
    callback open-dbc();
    callback open-dbc-catalog();
    callback begin-edit();
    callback undo-dbc();
    callback save-dbc();
    callback save-dbc-as();
    callback field-edited();
    callback add-message();
    callback delete-message();
    callback add-signal();
    callback delete-signal();
    callback add-node();
    callback delete-node();
    callback message-selected(int);
    callback signal-selected(int);
    callback node-selected(int);
    callback refresh-bit-map();
    callback bit-cell-clicked(int);

    in-out property <string> dbc-path: "";
    in-out property <bool> dirty: false;
    in-out property <string> version: "";
    in-out property <string> comment: "";
    in-out property <[DbcMessageRow]> messages;
    in-out property <[DbcSignalRow]> signals;
    in-out property <[DbcNodeRow]> nodes;
    in-out property <[DbcAttributeRow]> attributes;
    in-out property <[DbcValueDescRow]> value-descriptions;
    in-out property <[DbcBitBand]> bit-bands;
    in-out property <string> bit-summary: "";
    in-out property <int> bit-dlc: 0;
    in-out property <int> selected-message: -1;
    in-out property <int> selected-signal: -1;
    in-out property <int> selected-node: -1;
    in-out property <string> edit-message-id: "";
    in-out property <string> edit-message-name: "";
    in-out property <string> edit-message-dlc: "8";
    in-out property <string> edit-message-sender: "";
    in-out property <string> edit-signal-name: "";
    in-out property <string> edit-signal-start: "0";
    in-out property <string> edit-signal-length: "8";
    in-out property <string> edit-signal-factor: "1";
    in-out property <string> edit-signal-offset: "0";
    in-out property <string> edit-signal-unit: "";
    in-out property <string> edit-signal-byte-order: "Intel";
    in-out property <string> edit-node-name: "";
    in-out property <string> edit-node-comment: "";
    // 0 Messages, 1 Nodes, 2 Header, 3 Attributes, 4 Val Desc
    in-out property <int> editor-panel: 0;
    /// false = view (default), true = edit
    in-out property <bool> editing: false;
    in-out property <bool> undo-confirm-open: false;

    background: SigmaTheme.background;

    VerticalLayout {
        padding: 8px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;
            ToolbarButton {
                label: "Catalog";
                clicked => { root.open-dbc-catalog(); }
            }
            ToolbarButton {
                label: "New";
                clicked => {
                    root.editing = true;
                    root.new-dbc();
                }
            }
            if !root.editing: ToolbarButton {
                label: "Edit";
                clicked => {
                    root.begin-edit();
                    root.editing = true;
                }
            }
            if root.editing: ToolbarButton {
                label: "Undo";
                enabled: root.dirty;
                clicked => { root.undo-confirm-open = true; }
            }
            if root.editing: ToolbarButton {
                label: "Save";
                enabled: root.dirty;
                clicked => { root.save-dbc(); }
            }
            ToolbarButton {
                label: "Save As";
                clicked => { root.save-dbc-as(); }
            }
            if root.dirty: StatusChip {
                label: "";
                value: "● Modified";
                value-color: SigmaTheme.accent-amber;
            }
            Rectangle { horizontal-stretch: 1; }
        }

        HorizontalLayout {
            spacing: 4px;
            ToolbarButton {
                label: "Messages";
                selected: root.editor-panel == 0;
                clicked => { root.editor-panel = 0; }
            }
            ToolbarButton {
                label: "Nodes";
                selected: root.editor-panel == 1;
                clicked => { root.editor-panel = 1; }
            }
            ToolbarButton {
                label: "Attributes";
                selected: root.editor-panel == 3;
                clicked => { root.editor-panel = 3; }
            }
            ToolbarButton {
                label: "Val Desc";
                selected: root.editor-panel == 4;
                clicked => { root.editor-panel = 4; }
            }
            ToolbarButton {
                label: "Header";
                selected: root.editor-panel == 2;
                clicked => { root.editor-panel = 2; }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: SigmaTheme.surface;
            border-radius: 4px;
            border-width: 1px;
            border-color: SigmaTheme.border;

            // Messages: list on top, detail editor for the selection below.
            if root.editor-panel == 0: VerticalLayout {
                padding: 4px;
                spacing: 4px;

                if root.editing: HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    ToolbarButton { label: "+ Message"; clicked => { root.add-message(); } }
                    ToolbarButton { label: "− Message"; danger: true; clicked => { root.delete-message(); } }
                }

                if root.messages.length == 0: EmptyState {
                    vertical-stretch: 1;
                    message: "No DBC loaded";
                    hint: "Open a DBC with the header button, load one from the Catalog, or start a New one.";
                }

                if root.messages.length > 0: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 4px;

                    TableHeader {
                        HeaderCell { text: "ID"; width: 80px; }
                        HeaderCell { text: "Name"; width: 140px; }
                        HeaderCell { text: "DLC"; width: 56px; }
                        HeaderCell { text: "Sender"; width: 100px; }
                        HeaderCell { text: "Signals"; horizontal-stretch: 1; }
                    }
                    ListView {
                        vertical-stretch: 1;
                        for msg[i] in root.messages: TableRow {
                            selected: i == root.selected-message;
                            clicked => { root.message-selected(i); }
                            Cell { text: msg.id; width: 80px; color: SigmaTheme.accent-amber; }
                            Cell { text: msg.name; width: 140px; }
                            Cell { text: msg.dlc; width: 56px; color: SigmaTheme.text-dim; }
                            Cell { text: msg.sender; width: 100px; color: SigmaTheme.text-dim; }
                            Cell { text: msg.signal-count; horizontal-stretch: 1; color: SigmaTheme.text-dim; }
                        }
                    }

                    if root.selected-message >= 0: Rectangle {
                        vertical-stretch: 1;
                        background: SigmaTheme.surface-raised.transparentize(0.5);
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: SigmaTheme.border;

                        ScrollView {
                            VerticalLayout {
                                padding: 10px;
                                spacing: 8px;
                                alignment: start;

                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;
                                    CompactField {
                                        label: "ID (hex)";
                                        text <=> root.edit-message-id;
                                        read-only: !root.editing;
                                        width: 88px;
                                        edited => { root.field-edited(); }
                                    }
                                    CompactField {
                                        label: "Name";
                                        text <=> root.edit-message-name;
                                        read-only: !root.editing;
                                        horizontal-stretch: 1;
                                        edited => { root.field-edited(); }
                                    }
                                    CompactField {
                                        label: "DLC";
                                        text <=> root.edit-message-dlc;
                                        read-only: !root.editing;
                                        width: 48px;
                                        edited => { root.field-edited(); }
                                    }
                                    CompactField {
                                        label: "Sender";
                                        text <=> root.edit-message-sender;
                                        read-only: !root.editing;
                                        width: 120px;
                                        edited => { root.field-edited(); }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 6px;
                                    alignment: start;
                                    Text {
                                        text: "Signals (" + root.signals.length + ")";
                                        color: SigmaTheme.text;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    if root.editing: ToolbarButton { label: "+ Signal"; clicked => { root.add-signal(); } }
                                    if root.editing: ToolbarButton { label: "− Signal"; danger: true; clicked => { root.delete-signal(); } }
                                }

                                if root.signals.length == 0: Text {
                                    text: "This message has no signals yet.";
                                    color: SigmaTheme.text-dim;
                                    font-size: SigmaTheme.font-size-small;
                                }

                                if root.signals.length > 0: VerticalLayout {
                                    TableHeader {
                                        HeaderCell { text: "Signal"; width: 120px; }
                                        HeaderCell { text: "Start"; width: 56px; }
                                        HeaderCell { text: "Length"; width: 56px; }
                                        HeaderCell { text: "Order"; width: 72px; }
                                        HeaderCell { text: "Factor"; width: 64px; }
                                        HeaderCell { text: "Unit"; horizontal-stretch: 1; }
                                    }
                                    for sig[j] in root.signals: TableRow {
                                        selected: j == root.selected-signal;
                                        clicked => { root.signal-selected(j); }
                                        Cell { text: sig.name; width: 120px; color: SigmaTheme.accent; }
                                        Cell { text: sig.start-bit; width: 56px; color: SigmaTheme.text-dim; }
                                        Cell { text: sig.length; width: 56px; color: SigmaTheme.text-dim; }
                                        Cell {
                                            text: sig.byte-order;
                                            width: 72px;
                                            color: sig.byte-order == "Motorola"
                                                ? SigmaTheme.accent-amber
                                                : SigmaTheme.text-dim;
                                        }
                                        Cell { text: "×" + sig.factor; width: 64px; color: SigmaTheme.text-dim; }
                                        Cell { text: sig.unit; horizontal-stretch: 1; color: SigmaTheme.text-dim; }
                                    }
                                }

                                if root.selected-signal >= 0: HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;
                                    CompactField {
                                        label: "Name";
                                        text <=> root.edit-signal-name;
                                        read-only: !root.editing;
                                        horizontal-stretch: 1;
                                        edited => { root.field-edited(); }
                                    }
                                    CompactField {
                                        label: "Start";
                                        text <=> root.edit-signal-start;
                                        read-only: !root.editing;
                                        width: 52px;
                                        edited => { root.field-edited(); }
                                    }
                                    CompactField {
                                        label: "Length";
                                        text <=> root.edit-signal-length;
                                        read-only: !root.editing;
                                        width: 52px;
                                        edited => { root.field-edited(); }
                                    }
                                    VerticalLayout {
                                        spacing: 2px;
                                        width: 168px;
                                        Text {
                                            text: "Endian";
                                            color: SigmaTheme.text-dim;
                                            font-size: SigmaTheme.font-size-small;
                                            height: 14px;
                                        }
                                        HorizontalLayout {
                                            spacing: 4px;
                                            ToolbarButton {
                                                label: "Intel";
                                                height: 24px;
                                                selected: root.edit-signal-byte-order == "Intel";
                                                enabled: root.editing;
                                                clicked => {
                                                    root.edit-signal-byte-order = "Intel";
                                                    root.field-edited();
                                                }
                                            }
                                            ToolbarButton {
                                                label: "Motorola";
                                                height: 24px;
                                                selected: root.edit-signal-byte-order == "Motorola";
                                                enabled: root.editing;
                                                clicked => {
                                                    root.edit-signal-byte-order = "Motorola";
                                                    root.field-edited();
                                                }
                                            }
                                        }
                                    }
                                    CompactField {
                                        label: "Factor";
                                        text <=> root.edit-signal-factor;
                                        read-only: !root.editing;
                                        width: 64px;
                                        edited => { root.field-edited(); }
                                    }
                                    CompactField {
                                        label: "Offset";
                                        text <=> root.edit-signal-offset;
                                        read-only: !root.editing;
                                        width: 64px;
                                        edited => { root.field-edited(); }
                                    }
                                    CompactField {
                                        label: "Unit";
                                        text <=> root.edit-signal-unit;
                                        read-only: !root.editing;
                                        width: 72px;
                                        edited => { root.field-edited(); }
                                    }
                                }

                                SignalBitMap {
                                    bands: root.bit-bands;
                                    summary: root.bit-summary;
                                    dlc: root.bit-dlc;
                                    cell-clicked(sig-idx) => { root.bit-cell-clicked(sig-idx); }
                                }
                            }
                        }
                    }
                }
            }

            if root.editor-panel == 1: VerticalLayout {
                padding: 4px;
                spacing: 4px;
                if root.editing: HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    ToolbarButton { label: "+ Node"; clicked => { root.add-node(); } }
                    ToolbarButton { label: "− Node"; danger: true; clicked => { root.delete-node(); } }
                }
                if root.nodes.length == 0: EmptyState {
                    vertical-stretch: 1;
                    message: "No nodes defined";
                }
                if root.nodes.length > 0: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 4px;
                    TableHeader {
                        HeaderCell { text: "Node"; width: 120px; }
                        HeaderCell { text: "Comment"; horizontal-stretch: 1; }
                    }
                    ListView {
                        vertical-stretch: 1;
                        for node[i] in root.nodes: TableRow {
                            selected: i == root.selected-node;
                            clicked => { root.node-selected(i); }
                            Cell { text: node.name; width: 120px; }
                            Cell { text: node.comment; horizontal-stretch: 1; color: SigmaTheme.text-dim; }
                        }
                    }
                    if root.selected-node >= 0: HorizontalLayout {
                        padding: 6px;
                        spacing: 8px;
                        alignment: start;
                        CompactField {
                            label: "Name";
                            text <=> root.edit-node-name;
                            read-only: !root.editing;
                            width: 160px;
                            edited => { root.field-edited(); }
                        }
                        CompactField {
                            label: "Comment";
                            text <=> root.edit-node-comment;
                            read-only: !root.editing;
                            horizontal-stretch: 1;
                            edited => { root.field-edited(); }
                        }
                    }
                }
            }

            if root.editor-panel == 2: VerticalLayout {
                padding: 12px;
                spacing: 6px;
                alignment: start;
                Text { text: "DBC Header"; color: SigmaTheme.text; font-weight: 600; }
                CompactField {
                    label: "Version";
                    text <=> root.version;
                    read-only: !root.editing;
                    width: 240px;
                    edited => { root.field-edited(); }
                }
                CompactField {
                    label: "Comment";
                    text <=> root.comment;
                    read-only: !root.editing;
                    width: 480px;
                    edited => { root.field-edited(); }
                }
            }

            if root.editor-panel == 3: VerticalLayout {
                padding: 4px;
                spacing: 4px;
                if root.attributes.length == 0: EmptyState {
                    vertical-stretch: 1;
                    message: "No attribute definitions";
                }
                if root.attributes.length > 0: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 4px;
                    TableHeader {
                        HeaderCell { text: "Attribute"; width: 120px; }
                        HeaderCell { text: "Object"; width: 80px; }
                        HeaderCell { text: "Value"; horizontal-stretch: 1; }
                    }
                    ListView {
                        for attr in root.attributes: TableRow {
                            hoverable: false;
                            Cell { text: attr.name; width: 120px; color: SigmaTheme.accent; }
                            Cell { text: attr.object-type; width: 80px; color: SigmaTheme.text-dim; }
                            Cell { text: attr.value-summary; horizontal-stretch: 1; }
                        }
                    }
                }
            }

            if root.editor-panel == 4: VerticalLayout {
                padding: 4px;
                spacing: 4px;
                if root.value-descriptions.length == 0: EmptyState {
                    vertical-stretch: 1;
                    message: "No value descriptions (VAL_)";
                }
                if root.value-descriptions.length > 0: VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 4px;
                    TableHeader {
                        HeaderCell { text: "Message"; width: 80px; }
                        HeaderCell { text: "Signal"; width: 100px; }
                        HeaderCell { text: "Entries"; horizontal-stretch: 1; }
                    }
                    ListView {
                        for vd in root.value-descriptions: TableRow {
                            hoverable: false;
                            Cell { text: vd.message-id; width: 80px; color: SigmaTheme.accent-amber; }
                            Cell { text: vd.signal-name; width: 100px; color: SigmaTheme.accent; }
                            Cell { text: vd.entries; horizontal-stretch: 1; color: SigmaTheme.text-dim; }
                        }
                    }
                }
            }
        }
    }

    if root.undo-confirm-open: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000088;
        TouchArea { clicked => { root.undo-confirm-open = false; } }

        Rectangle {
            width: 360px;
            height: 140px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: SigmaTheme.surface-raised;
            border-radius: 6px;
            border-width: 1px;
            border-color: SigmaTheme.border;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: "Revert all changes?";
                    color: SigmaTheme.text;
                    font-weight: 600;
                }
                Text {
                    text: "This restores the DBC to how it was when you started editing. Unsaved edits will be lost.";
                    color: SigmaTheme.text-dim;
                    font-size: SigmaTheme.font-size-small;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    Rectangle { horizontal-stretch: 1; }
                    ToolbarButton {
                        label: "Cancel";
                        clicked => { root.undo-confirm-open = false; }
                    }
                    ToolbarButton {
                        label: "Revert";
                        danger: true;
                        clicked => {
                            root.undo-confirm-open = false;
                            root.undo-dbc();
                        }
                    }
                }
            }
        }
    }
}
