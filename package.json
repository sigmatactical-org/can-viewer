    "@tauri-apps/cli": "^2",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "marked": "^17.0.1",
    "mitt": "^3.0.1"
