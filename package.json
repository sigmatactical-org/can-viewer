{
  "name": "can-viewer",
  "version": "0.2.6",
  "description": "CAN Data Viewer - Reusable component for viewing CAN bus data",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
