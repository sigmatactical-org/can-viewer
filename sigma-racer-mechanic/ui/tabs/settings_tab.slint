import { ListView } from "std-widgets.slint";
import { SigmaTheme } from "theme.slint";
import { ToolbarButton } from "widgets/common.slint";

export struct SettingRow {
    key: string,
    value: string,
    read-only: bool,
}

export component SettingsTab inherits Rectangle {
    callback refresh-settings();
    in property <bool> connected: false;
    in property <string> status-text: "";
    in property <[SettingRow]> settings;

    background: SigmaTheme.background;

    VerticalLayout {
        padding: 12px;
        spacing: 10px;
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Settings";
                color: SigmaTheme.text;
                font-weight: 700;
                vertical-alignment: center;
            }
            ToolbarButton {
                label: "Refresh";
                clicked => { root.refresh-settings(); }
            }
        }
        Text {
            text: root.status-text;
            color: SigmaTheme.text-dim;
            wrap: word-wrap;
            font-size: SigmaTheme.font-size-small;
        }
        Rectangle {
            vertical-stretch: 1;
            background: SigmaTheme.surface;
            border-radius: 4px;
            border-width: 1px;
            border-color: SigmaTheme.border;
            ListView {
                for row in root.settings: Rectangle {
                    height: SigmaTheme.row-height;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 8px;
                        Text {
                            text: row.key;
                            width: 180px;
                            color: SigmaTheme.accent;
                            font-size: SigmaTheme.font-size-small;
                            vertical-alignment: center;
                        }
                        Text {
                            text: row.value;
                            horizontal-stretch: 1;
                            color: SigmaTheme.text;
                            font-size: SigmaTheme.font-size-small;
                            vertical-alignment: center;
                        }
                        Text {
                            text: row.read-only ? "ro" : "rw";
                            width: 28px;
                            color: SigmaTheme.text-dim;
                            font-size: SigmaTheme.font-size-small;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
