//
// Placeholder cluster layout. Deliberately free of proprietary Sigma
// Tactical Group artwork and wordmarks (see BRANDING.md at the repo
// root): official builds inject brand assets at build time; this open
// layout ships with neutral styling only.

global ClusterTheme {
    in-out property <brush> background: #0a0a0a;
    in-out property <brush> surface: #161616;
    in-out property <brush> border: #2e2e2e;
    in-out property <brush> text: #f0f0f0;
    in-out property <brush> text-dim: #8a8a8a;
    in-out property <brush> accent: #3b82f6;
    in-out property <brush> warn: #f59e0b;
    in-out property <brush> alert: #ef4444;
    in-out property <brush> ok: #22c55e;
}

component Readout inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <brush> value-color: ClusterTheme.text;
    background: ClusterTheme.surface;
    border-radius: 8px;
    border-width: 1px;
    border-color: ClusterTheme.border;
    VerticalLayout {
        padding: 12px;
        spacing: 4px;
        Text {
            text: root.label;
            color: ClusterTheme.text-dim;
            font-size: 14px;
        }
        Text {
            text: root.value;
            color: root.value-color;
            font-size: 28px;
            font-weight: 700;
            overflow: elide;
        }
    }
}

export component ClusterWindow inherits Window {
    title: "Cluster";
    preferred-width: 800px;
    preferred-height: 480px;
    background: ClusterTheme.background;

    in-out property <bool> connected: false;
    in-out property <string> rpm: "—";
    in-out property <string> gear: "N";
    in-out property <string> mode: "—";
    in-out property <string> coolant: "—";
    in-out property <string> oil: "—";
    in-out property <string> dtc-count: "—";
    in-out property <string> status: "Waiting for bus…";

    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        // Top strip: mode + link state.
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: root.mode;
                color: ClusterTheme.accent;
                font-size: 18px;
                font-weight: 700;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            Rectangle {
                width: 12px;
                height: 12px;
                y: (parent.height - self.height) / 2;
                border-radius: 6px;
                background: root.connected ? ClusterTheme.ok : ClusterTheme.alert;
            }
            Text {
                text: root.connected ? "LINK" : "NO LINK";
                color: ClusterTheme.text-dim;
                font-size: 14px;
                vertical-alignment: center;
            }
        }

        // Center: gear dominates, RPM beside it.
        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 16px;
            Rectangle {
                horizontal-stretch: 1;
                background: ClusterTheme.surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: ClusterTheme.border;
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: root.gear;
                        color: ClusterTheme.text;
                        font-size: 160px;
                        font-weight: 900;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "GEAR";
                        color: ClusterTheme.text-dim;
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                }
            }
            Rectangle {
                horizontal-stretch: 2;
                background: ClusterTheme.surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: ClusterTheme.border;
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: root.rpm;
                        color: ClusterTheme.text;
                        font-size: 96px;
                        font-weight: 900;
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                    Text {
                        text: "RPM";
                        color: ClusterTheme.text-dim;
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // Bottom strip: temperatures and faults.
        HorizontalLayout {
            spacing: 12px;
            height: 88px;
            Readout { label: "COOLANT"; value: root.coolant; horizontal-stretch: 1; }
            Readout { label: "OIL"; value: root.oil; horizontal-stretch: 1; }
            Readout {
                label: "DTC";
                value: root.dtc-count;
                value-color: root.dtc-count == "0" || root.dtc-count == "—"
                    ? ClusterTheme.text
                    : ClusterTheme.warn;
                horizontal-stretch: 1;
            }
        }

        Text {
            text: root.status;
            color: ClusterTheme.text-dim;
            font-size: 14px;
        }
    }
}
